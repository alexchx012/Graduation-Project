[ORDER 083] CMD: @'
from isaacsim import SimulationApp
simulation_app = SimulationApp({'headless': True})
import omni.graph.core as og
from isaacsim.core.api import SimulationContext

keys = og.Controller.Keys
og.Controller.edit(
    {'graph_path': '/TestExecGraph', 'evaluator_name': 'execution'},
    {
        keys.CREATE_NODES: [
            ('OnTick', 'omni.graph.action.OnTick'),
        ],
    },
)

attr = og.Controller.attribute('/TestExecGraph/OnTick.outputs:tick')

sim = SimulationContext(physics_dt=1.0/60.0, rendering_dt=1.0/60.0)
sim.initialize_physics()
sim.play()

vals = []
for _ in range(8):
    simulation_app.update()
    vals.append(og.Controller.get(attr))

print('EXEC_VALUES', vals)
print('EXEC_TYPES', [type(v).__name__ for v in vals])

sim.stop()
simulation_app.close()
'@ | .\Isaacsim\python.bat -
