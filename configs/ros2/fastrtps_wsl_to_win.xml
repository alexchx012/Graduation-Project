<?xml version="1.0" encoding="UTF-8" ?>
<!--
Fast DDS profile for WSL2 ROS2 publisher in mirrored mode.

In mirrored networking mode, WSL2 shares the Windows network stack.
Both sides can communicate via localhost (127.0.0.1).

This profile:
  1) advertises WSL2 unicast locators on 127.0.0.1
  2) probes Windows initial peers on 127.0.0.1
  3) disables SHM by forcing UDPv4 transport only

Updated 2026-03-08: Changed metatrafficUnicast and defaultUnicast from
stale 192.168.0.104 to 127.0.0.1 to match mirrored mode topology.
-->
<profiles xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">
    <transport_descriptors>
        <transport_descriptor>
            <transport_id>udp_transport</transport_id>
            <type>UDPv4</type>
        </transport_descriptor>
    </transport_descriptors>

    <participant profile_name="participant_profile" is_default_profile="true">
        <rtps>
            <!-- Prevent Fast DDS from preferring SHM across Windows/WSL2 boundary. -->
            <userTransports>
                <transport_id>udp_transport</transport_id>
            </userTransports>
            <useBuiltinTransports>false</useBuiltinTransports>

            <builtin>
                <!-- Advertise metatraffic on localhost (reachable from Windows). -->
                <metatrafficUnicastLocatorList>
                    <locator>
                        <udpv4>
                            <address>127.0.0.1</address>
                            <port>0</port>
                        </udpv4>
                    </locator>
                </metatrafficUnicastLocatorList>

                <!-- Probe Windows subscriber on localhost (mirrored mode). -->
                <initialPeersList>
                    <locator><udpv4><address>127.0.0.1</address><port>7410</port></udpv4></locator>
                    <locator><udpv4><address>127.0.0.1</address><port>7412</port></udpv4></locator>
                    <locator><udpv4><address>127.0.0.1</address><port>7414</port></udpv4></locator>
                    <locator><udpv4><address>127.0.0.1</address><port>7416</port></udpv4></locator>
                    <locator><udpv4><address>127.0.0.1</address><port>7418</port></udpv4></locator>
                    <locator><udpv4><address>127.0.0.1</address><port>7420</port></udpv4></locator>
                </initialPeersList>
            </builtin>

            <!-- Advertise user-data unicast locator reachable from Windows. -->
            <defaultUnicastLocatorList>
                <locator>
                    <udpv4>
                        <address>127.0.0.1</address>
                        <port>0</port>
                    </udpv4>
                </locator>
            </defaultUnicastLocatorList>
        </rtps>
    </participant>
</profiles>
